{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: sim",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/sim",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "preLaunchTask": "CMake: Build"
        },
        {
            "name": "Debug: bd_tests (all)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/test/bd_tests",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "preLaunchTask": "CMake: Build"
        },
        {
            "name": "Debug: bd_tests (filter)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/test/bd_tests",
            "args": ["--gtest_filter=${input:gtestFilter}"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "preLaunchTask": "CMake: Build"
        }
    ],
    "inputs": [
        {
            "id": "gtestFilter",
            "type": "promptString",
            "description": "GTest filter (e.g. CellListTest.* or ForceCalculatorTest.ForceAtSigmaSeparation)",
            "default": "*"
        }
    ]
